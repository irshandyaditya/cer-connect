generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  fullName String

  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  group   Group?  @relation(fields: [groupId], references: [id])
  groupId String?

  submissions Submission[]

  mapsCreated Map[] @relation("UserCreatedMaps")

  createdAt DateTime @default(now())
}

model Role {
  id   String   @id @default(cuid())
  name RoleType @unique

  users User[]
}

model Group {
  id   String @id @default(cuid())
  name String

  users User[]
  maps  Map[]
}

model Map {
  id          String  @id @default(cuid())
  title       String
  description String?
  documentUrl String?

  timeoutAt DateTime

  group   Group  @relation(fields: [groupId], references: [id])
  groupId String

  cards       Card[]
  connections Connection[]

  createdBy User   @relation("UserCreatedMaps", fields: [teacherId], references: [id])
  teacherId String

  submissions Submission[]

  createdAt DateTime @default(now())
}

model Card {
  id     String     @id @default(cuid())
  text   String
  column ColumnType

  map   Map    @relation(fields: [mapId], references: [id])
  mapId String

  // reference connections (jawaban guru)
  fromConnections Connection[] @relation("fromCard")
  toConnections   Connection[] @relation("toCard")
}

model Connection {
  id String @id @default(cuid())

  map   Map    @relation(fields: [mapId], references: [id])
  mapId String

  from   Card   @relation("fromCard", fields: [fromId], references: [id])
  fromId String

  to   Card   @relation("toCard", fields: [toId], references: [id])
  toId String

  @@unique([fromId, toId])
}

model Submission {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  map   Map    @relation(fields: [mapId], references: [id])
  mapId String

  answers AnswerConnection[]

  score Float?

  submittedAt DateTime @default(now())
}

model AnswerConnection {
  id String @id @default(cuid())

  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String

  fromId String
  toId   String

  @@unique([submissionId, fromId, toId])
}
